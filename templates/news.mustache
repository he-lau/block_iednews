{{!
    @template block_iednews/news
}}
<div id="{{carouselid}}" class="carousel slide block-iednews" data-ride="carousel" data-interval="{{interval}}">
    {{#showcontrols}}
        <div class="d-flex justify-content-between align-items-center mb-2 block-iednews-sliderbar">
            <div class="block-iednews-count">{{newscount}}</div>
            <div class="block-iednews-pagingbar">
                {{#pagingbar}}
                    {{> core/paged_content_paging_bar }}
                {{/pagingbar}}
                <button type="button" class="page-link block-iednews-pause"
                        aria-pressed="false" aria-label="{{pause}}" title="{{pause}}"
                        data-pause-label="{{pause}}" data-resume-label="{{resume}}">
                    <span class="block-iednews-pause-icon" aria-hidden="true">
                        <span></span><span></span>
                    </span>
                    <span class="block-iednews-resume-icon d-none" aria-hidden="true"></span>
                    <span class="sr-only block-iednews-pause-label">{{pause}}</span>
                </button>
            </div>
        </div>
        <div class="block-iednews-position" aria-live="polite">
            <span class="block-iednews-current">1</span>/<span class="block-iednews-total">{{totalitems}}</span>
        </div>
    {{/showcontrols}}
    {{^showcontrols}}
        <div class="block-iednews-count block-iednews-count-single mx-auto mb-2">{{newscount}}</div>
    {{/showcontrols}}
    <div class="carousel-inner">
        {{#items}}
            <article class="carousel-item{{#active}} active{{/active}}">
                <h5 class="mb-1">{{title}}</h5>
                {{#showdate}}<div class="text-muted small mb-1">{{date}}</div>{{/showdate}}
                <div class="block-iednews-visibility-reason text-muted small mb-2">{{visibilityreason}}</div>
                <div class="block-iednews-content">{{{content}}}</div>
            </article>
        {{/items}}
    </div>
</div>
{{#js}}
require(['block_iednews/carousel'], function(carousel) {
    carousel.init('{{carouselid}}');
});
{{/js}}
